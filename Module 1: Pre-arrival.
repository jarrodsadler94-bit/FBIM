import streamlit as st
import pandas as pd

# --- DATA DICTIONARIES (Based on AFAC Dataset) ---

table_a_data = {
    "AS 2118.1": 360, # Using upper bound of 180-360s range for conservative default
    "Combined OHI < 1000m2": 10,
    "Combined OHI 1000m2 - 2000m2": 20,
    "Combined OHI > 2000m2": 50,
    "N/A": 0
}

table_c_data = {
    "Receive and take down verbal information": 60,
    "Alternative option (defaulting to 0 for now)": 0 
}

table_d_data = {
    "Fully electronic CAD": 0,
    "Part manual CAD": 15,
    "Phone or radio": 30
}

table_e_data = {
    "Travel to station, dress, assemble, leave": 480,
    "Dress, assimilate info, depart (career staff)": 90,
    "Make up and become mobile": 60
}

# --- APP LAYOUT & LOGIC ---

st.title("FBIM Calculator - Module 1: Pre-Arrival")
st.markdown("Calculates the cumulative time from initial alarm to brigade arrival.")

# Global Toggle
st.sidebar.header("Global Settings")
stat_mode = st.sidebar.radio("Statistical Mode", ["Mean", "95th Percentile"])

st.header("1. System Depressurisation & Alarm Activation (Table A)")
sys_type = st.selectbox("Select System Type / Floor Area", list(table_a_data.keys()))
time_a = table_a_data[sys_type]
st.write(f"**Time:** {time_a} seconds")

st.header("2. Alarms, Verification & Notification (Table B)")
# Time delay for alarm verification is fixed at 20s in the dataset
alarm_verif_time = 20 
st.write(f"Time delay for alarm verification: **{alarm_verif_time} seconds**")
time_b = alarm_verif_time

st.header("3. Receipt of Information (Table C)")
receipt_type = st.selectbox("Select Information Receipt Method", list(table_c_data.keys()))
time_c = table_c_data[receipt_type]
st.write(f"**Time:** {time_c} seconds")

st.header("4. Dispatch Times (Table D)")
dispatch_type = st.selectbox("Select Dispatch Method", list(table_d_data.keys()))
time_d = table_d_data[dispatch_type]
st.write(f"**Time:** {time_d} seconds")

st.header("5. Firefighter Response (Table E)")
response_type = st.selectbox("Select Firefighter Turnout Activity", list(table_e_data.keys()))
time_e = table_e_data[response_type]
st.write(f"**Time:** {time_e} seconds")

# Calculate Total Pre-Arrival Time (excluding travel time for now)
total_pre_arrival = time_a + time_b + time_c + time_d + time_e

st.markdown("---")
st.subheader("Module 1 Cumulative Time (Pre-Travel)")
st.write(f"### {total_pre_arrival} seconds")
st.write(f"### {round(total_pre_arrival/60, 2)} minutes")
